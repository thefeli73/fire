{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "oxc",
    "unicorn",
    "typescript",
    "react",
    "import",
    "jsx-a11y",
    "nextjs"
  ],
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "next-env.d.ts",
    "*.mjs",
    "tailwind.config.ts"
  ]
}
